{
  "name": "ph_sensor",
  "display_name": { "zh": "pH传感器", "en": "pH Sensor" },
  "description": {
    "zh": "工业pH传感器，测量范围0-14pH，精度±0.1pH，用于水处理和化工过程控制",
    "en": "Industrial pH sensor, range 0-14pH, accuracy ±0.1pH, for water treatment and chemical process control"
  },
  "version": "1.0.0",
  "author": "TinyIoT",
  "category": "sensors",
  "manufacturer": "TinyIoT",
  "device_type": "sensor",
  "protocol_type": "modbus",
  "driver_name": "modbus_rtu",
  "tags": ["ph", "sensor", "water", "treatment"],
  "device_info": {
    "default_name_pattern": "ph_sensor_{index}",
    "default_display_name_pattern": { "zh": "pH传感器 {index}", "en": "pH Sensor {index}" },
    "required_fields": ["name", "address"]
  },
  "properties": [
    {"name": "ph_value", "display_name": { "zh": "pH值", "en": "pH Value" }, "description": { "zh": "当前pH值", "en": "Current pH value" }, "data_type": "number", "unit": "pH", "min_value": 0.0, "max_value": 14.0, "default_value": "7.0", "is_read_only": true, "is_required": true},
    {"name": "orp_value", "display_name": { "zh": "ORP值", "en": "ORP Value" }, "description": { "zh": "氧化还原电位", "en": "Oxidation-reduction potential" }, "data_type": "number", "unit": "mV", "min_value": -1000.0, "max_value": 1000.0, "default_value": "0.0", "is_read_only": true, "is_required": false},
    {"name": "temperature", "display_name": { "zh": "温度", "en": "Temperature" }, "description": { "zh": "溶液温度(用于补偿)", "en": "Solution temperature (for compensation)" }, "data_type": "number", "unit": "°C", "min_value": 0.0, "max_value": 100.0, "default_value": "25.0", "is_read_only": true, "is_required": false},
    {"name": "alarm_high", "display_name": { "zh": "高pH报警", "en": "High pH Alarm" }, "description": { "zh": "pH值过高报警", "en": "High pH alarm threshold" }, "data_type": "number", "unit": "pH", "min_value": 0.0, "max_value": 14.0, "default_value": "9.0", "is_read_only": false, "is_required": false},
    {"name": "alarm_low", "display_name": { "zh": "低pH报警", "en": "Low pH Alarm" }, "description": { "zh": "pH值过低报警", "en": "Low pH alarm threshold" }, "data_type": "number", "unit": "pH", "min_value": 0.0, "max_value": 14.0, "default_value": "5.0", "is_read_only": false, "is_required": false},
    {"name": "electrode_status", "display_name": { "zh": "电极状态", "en": "Electrode Status" }, "description": { "zh": "电极老化状态", "en": "Electrode aging status" }, "data_type": "number", "unit": "%", "min_value": 0.0, "max_value": 100.0, "default_value": "100.0", "is_read_only": true, "is_required": false}
  ],
  "commands": [
    {"name": "read_ph", "display_name": { "zh": "读取pH", "en": "Read pH" }, "description": { "zh": "读取pH值", "en": "Read pH value" }, "parameters": "{}", "is_required": true},
    {"name": "calibrate_7", "display_name": { "zh": "校准pH7", "en": "Calibrate pH7" }, "description": { "zh": "pH7点校准", "en": "pH7 point calibration" }, "parameters": "{\"buffer\": 7.0}", "parameter_schema": "{\"type\": \"object\", \"properties\": {\"buffer\": {\"type\": \"number\", \"minimum\": 6.8, \"maximum\": 7.2}}, \"required\": [\"buffer\"]}", "is_required": false},
    {"name": "calibrate_4", "display_name": { "zh": "校准pH4", "en": "Calibrate pH4" }, "description": { "zh": "pH4点校准", "en": "pH4 point calibration" }, "parameters": "{\"buffer\": 4.0}", "parameter_schema": "{\"type\": \"object\", \"properties\": {\"buffer\": {\"type\": \"number\", \"minimum\": 3.8, \"maximum\": 4.2}}, \"required\": [\"buffer\"]}", "is_required": false}
  ]
}
